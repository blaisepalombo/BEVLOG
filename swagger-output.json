                        "example": {
                          "type": "number",
                          "example": 16
                        }
                      }
                    },
                    "caffeineMg": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 200
                        }
                      }
                    },
                    "sugarG": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 0
