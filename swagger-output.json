{
  "swagger": "2.0",
  "info": {
    "title": "Energy Drink Log API",
    "description": "REST API for tracking energy drinks with MongoDB, Google OAuth, filtering, pagination, stats, and full CRUD operations.",
    "version": "1.1.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "tags": [
    {
      "name": "Drinks",
      "description": "Energy drink logging endpoints"
    },
    {
      "name": "Auth",
      "description": "Google OAuth and session endpoints"
    }
  ],
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "cookieAuth": {
      "type": "apiKey",
      "in": "cookie",
      "name": "sid",
      "description": "Session cookie set after logging in via /auth/google. Open /auth/google in the browser first, then use Swagger in the same browser session."
    }
  },
  "paths": {
    "/drinks/": {
      "get": {
        "tags": [
          "Drinks"
        ],
        "summary": "Get drink logs with filtering, sorting, and pagination",
        "description": "Returns drink entries with optional filtering by brand, search term, caffeine range, rating range, sorting, and pagination.",
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "type": "string"
          },
          {
            "name": "page",
            "in": "query",
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "type": "string"
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Filter by brand name",
            "type": "string"
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search by brand, drink name, or notes",
            "type": "string"
          },
          {
            "name": "minCaffeine",
            "in": "query",
            "description": "Minimum caffeine in mg",
            "type": "number"
          },
          {
            "name": "maxCaffeine",
            "in": "query",
            "description": "Maximum caffeine in mg",
            "type": "number"
          },
          {
            "name": "minRating",
            "in": "query",
            "description": "Minimum rating",
            "type": "number"
          },
          {
            "name": "maxRating",
            "in": "query",
            "description": "Maximum rating",
            "type": "number"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Drinks"
        ],
        "summary": "Create a new drink log",
        "description": "Requires login. Creates a new drink entry associated with the authenticated user.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Drink to create",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "object"
                },
                "required": {
                  "type": "array",
                  "example": [
                    "brand",
                    "drinkName",
                    "sizeOz"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "properties": {
                  "type": "object",
                  "properties": {
                    "brand": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "Ghost"
                        }
                      }
                    },
                    "drinkName": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "Blue Raspberry"
                        }
                      }
                    },
                    "sizeOz": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 16
                        }
                      }
                    },
                    "caffeineMg": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 200
                        }
                      }
                    },
                    "sugarG": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 0
                        }
                      }
                    },
                    "rating": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "number"
                        },
                        "example": {
                          "type": "number",
                          "example": 8
                        }
                      }
                    },
                    "notes": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "Testing the upgraded API"
                        }
                      }
                    },
                    "purchasedAt": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "2026-03-24T18:00:00.000Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/drinks/stats": {
      "get": {
        "tags": [
          "Drinks"
        ],
        "summary": "Get aggregated drink stats",
        "description": "Returns overall drink statistics, top brands, and top rated entries.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "type": "string"
          },
          {
            "name": "sort",
            "in": "query",
            "type": "string"
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Filter stats by brand name",
            "type": "string"
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search by brand, drink name, or notes",
            "type": "string"
          },
          {
            "name": "minCaffeine",
            "in": "query",
            "description": "Minimum caffeine in mg",
            "type": "number"
          },
          {
            "name": "maxCaffeine",
            "in": "query",
            "description": "Maximum caffeine in mg",
            "type": "number"
          },
          {
            "name": "minRating",
