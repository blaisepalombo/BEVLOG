    "/auth/google": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Start Google OAuth login",
        "description": "Redirects the user to Google to begin the OAuth login flow.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Google OAuth callback",
        "description": "Handles the Google OAuth callback and establishes the user session.",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current authenticated user",
        "description": "Returns the currently logged-in user if a valid session exists.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Log out current user",
        "description": "Ends the current session and clears the session cookie.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/auth/login-failed": {
      "get": {
        "tags": [
