      "delete": {
        "tags": [
          "Drinks"
        ],
        "summary": "Delete a drink log by ID",
        "description": "Requires login and ownership. Only the user who created the entry can delete it.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Drink ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
