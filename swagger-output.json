                        }
                      }
                    },
                    "purchasedAt": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "string"
                        },
                        "example": {
                          "type": "string",
                          "example": "2026-03-24T18:00:00.000Z"
